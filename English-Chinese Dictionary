            color: var(--primary);
            margin: 0;
            font-weight: bold;
        }
        .phonetic-group {
            text-align: right;
        }
        .pinyin {
            font-size: 22px;
            color: var(--accent);
            font-weight: bold;
        }
        .zhuyin {
            font-size: 18px;
            color: #555;
            background: #fff1f1;
            padding: 2px 8px;
            border-radius: 4px;
            margin-top: 5px;
            display: inline-block;
        }
        .ipa-tag {
            display: inline-block;
            background: #eee;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 14px;
            margin-top: 5px;
            font-family: monospace;
        }
