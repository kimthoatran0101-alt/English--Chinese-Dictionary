      n: { en: "Development / Growth", ex: "經濟的發展改變了人們的生活。(Economic development has changed people's lives.)" },
      adj: { en: "Developing / Developmental", ex: "發展中國家面臨著許多挑戰。(Developing countries face many challenges.)" },
