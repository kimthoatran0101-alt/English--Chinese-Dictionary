            overflow-y: auto;
            border: 1px solid #ddd;
            border-top: none;
            display: none;
        }
        .suggestion-item {
            padding: 12px 25px;
            cursor: pointer;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .suggestion-item:hover {
            background: #f0f7ff;
            color: var(--accent);
        }
        .word-card {
            border: 1px solid #e0e0e0;
            border-radius: 12px;
            padding: 30px;
            animation: fadeIn 0.4s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #eee;
