      { q: "What is the Zhuyin for the first character '學'?", a: ["ㄒㄧˊ", "ㄒㄩㄝˊ", "ㄈㄚ"], c: 1 },
      { q: "Which idiom means 'Knowledge has no limit'?", a: ["學而時習之", "學無止境", "蒸蒸日上"], c: 1 }
    ]
  },
  "發展": {
