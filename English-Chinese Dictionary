    <style>
        :root {
            --primary: #1d2a44;
            --accent: #d12127;
            --bg: #f4f7f9;
            --english-blue: #007bff;
        }
        body {
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            background: var(--bg);
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.1);
        }
        .header {
            background: var(--primary);
            color: white;
            padding: 25px;
            text-align: center;
            border-radius: 12px;
            margin-bottom: 30px;
        }
        .search-container {
            position: relative;
            margin-bottom: 30px;
            display: flex;
            gap: 10px;
        }
        .search-box {
            flex: 1;
            padding: 15px 25px;
            border: 2px solid var(--primary);
            border-radius: 30px;
            font-size: 18px;
            outline: none;
            box-sizing: border-box;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .search-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0 30px;
            border-radius: 30px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }
        .search-btn:hover {
            background: #2c3e50;
        }
        .suggestion-box {
            position: absolute;
            top: 100%;
            left: 0;
            background: white;
            width: 100%;
            z-index: 10;
            border-radius: 0 0 15px 15px;
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
