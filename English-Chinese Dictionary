// KỸ THUẬT SỬA LỖI ENTER CHUẨN XÁC: Lắng nghe sự kiện bằng addEventListener
document.getElementById("search").addEventListener("keydown", function(event) {
    if (event.key === "Enter") {
        event.preventDefault(); // Chặn hành vi submit làm reload trang vô lý
        executeSearch();        // Chạy hàm tìm kiếm
    }
});

// Logic thực thi tìm kiếm nâng cao (Dữ liệu ẩn hoàn toàn)
function executeSearch() {
    const query = document.getElementById("search").value.trim().toLowerCase();
    const suggestBox = document.getElementById("suggest");
    suggestBox.style.display = "none"; 

    if (!query) return;

    // 1. So khớp trực tiếp chữ Hán tự
    for (let key in dictionary) {
        if (query === key.toLowerCase()) {
            showWord(key);
            return;
        }
    }

    // 2. So khớp Pinyin viết liền hoặc từ khóa mảng mở rộng tiếng Anh
    for (let key in dictionary) {
        const cleanPinyin = dictionary[key].pinyin.toLowerCase().replace(/\s+/g, "");
        if (query === cleanPinyin || dictionary[key].searchKeywords.includes(query)) {
            showWord(key);
            return;
        }
    }

    // 3. Tìm kiếm gần đúng (Fuzzy search)
    for (let key in dictionary) {
        const cleanPinyin = dictionary[key].pinyin.toLowerCase().replace(/\s+/g, "");
        if (key.includes(query) || cleanPinyin.includes(query) || dictionary[key].searchKeywords.some(k => k.includes(query))) {
            showWord(key);
            return;
        }
    }

    // Trạng thái lỗi khi không tìm thấy
    document.getElementById("result").innerHTML = `
        <div class="word-card error-state">
            <h2>抱歉！找不到相關結果</h2>
            <p>Từ khóa "<b>${query}</b>" không có trong hệ thống dữ liệu ẩn. Vui lòng gõ chính xác: <b>study, develop, plan, 學習, 發展, 打算</b>.</p>
        </div>
    `;
}

// Xử lý hộp gợi ý (dropdown menu) khi đang gõ chữ
function handleSuggest() {
    const query = document.getElementById("search").value.trim().toLowerCase();
    const suggestBox = document.getElementById("suggest");
    suggestBox.innerHTML = "";
    
    if (!query) {
        suggestBox.style.display = "none";
        return;
    }
    
    let matches = [];
    for (let key in dictionary) {
        const cleanPinyin = dictionary[key].pinyin.toLowerCase().replace(/\s+/g, "");
        if (key.includes(query) || cleanPinyin.includes(query) || dictionary[key].searchKeywords.some(k => k.includes(query))) {
            matches.push(key);
        }
    }
    
    if (matches.length > 0) {
        suggestBox.style.display = "block";
        matches.forEach(word => {
            const item = document.createElement("div");
            item.className = "suggestion-item";
            item.innerHTML = `<span><b>${word}</b> (${dictionary[word].pinyin})</span><span style='color:#666;font-size:13px;'>${dictionary[word].searchKeywords[0]}</span>`;
            item.onclick = () => {
                document.getElementById("search").value = word;
                suggestBox.style.display = "none";
                showWord(word);
            };
            suggestBox.appendChild(item);
        });
    } else {
        suggestBox.style.display = "none";
    }
}

// Hàm render dựng cấu trúc HTML động từ kho lưu trữ ẩn
function showWord(wordKey) {
    const data = dictionary[wordKey];
    const resultDiv = document.getElementById("result");
    
    let quizHtml = "";
    if (data.quiz && data.quiz.length > 0) {
        quizHtml = `<div class="quiz-section"><h3>📊 Quick Quiz / Mini Test</h3>`;
        data.quiz.forEach((q, qIdx) => {
            quizHtml += `<div class="quiz-question"><p><b>Q${qIdx + 1}: ${q.q}</b></p>`;
            q.a.forEach((opt, oIdx) => {
                quizHtml += `<button class="quiz-option" onclick="checkQuiz(this, ${qIdx}, ${oIdx}, ${q.c}, '${wordKey}')">${opt}</button>`;
            });
            quizHtml += `</div>`;
        });
        quizHtml += `<div class="score-board" id="score-${wordKey}">Current Session Score: 0</div></div>`;
    }

    resultDiv.innerHTML = `
        <div class="word-card">
            <div class="header-flex">
                <div>
                    <h2 class="word-title">${wordKey}</h2>
                    <div class="audio-group">
                        <button class="audio-btn" onclick="speak('${wordKey}')">🔊 Speak (CN)</button>
                        <button class="audio-btn" onclick="speak('${data.searchKeywords[0]}', 'en-US')">🔊 Speak (EN)</button>
                    </div>
                </div>
                <div class="phonetic-group">
                    <div class="pinyin">${data.pinyin}</div>
                    <div class="zhuyin">${data.zhuyin}</div><br>
                    <div class="ipa-tag">CN IPA: ${data.ipa}</div><br>
                    <div class="ipa-tag" style="background:#e3f2fd;color:#007bff">EN IPA: ${data.englishIpa}</div>
                </div>
            </div>

            <div class="extra-info-grid">
                <div class="info-card">
                    <h4>✍️ Stroke Order (Bút thuận)</h4><br>
                    <div id="writer-area"></div>
                </div>
                <div class="info-card">
                    <h4>🌿 Word Family & Context</h4>
                    <ul>${data.wordFamily.map(f => `<li>${f}</li>`).join('')}</ul>
                </div>
            </div>

            <h3>💡 Parts of Speech & Academic Context</h3>
            <div class="pos-grid">
                ${data.pos.v ? `<div class="pos-item v"><span class="pos-label">VERB (動詞)</span><b>${data.pos.v.en}</b><p style="margin:5px 0 0 0; font-style:italic;">${data.pos.v.ex}</p></div>` : ''}
                ${data.pos.n ? `<div class="pos-item n"><span class="pos-label">NOUN (名詞)</span><b>${data.pos.n.en}</b><p style="margin:5px 0 0 0; font-style:italic;">${data.pos.n.ex}</p></div>` : ''}
                ${data.pos.adj ? `<div class="pos-item adj"><span class="pos-label">ADJECTIVE (形容詞)</span><b>${data.pos.adj.en}</b><p style="margin:5px 0 0 0; font-style:italic;">${data.pos.adj.ex}</p></div>` : ''}
                ${data.pos.adv ? `<div class="pos-item adv"><span class="pos-label">ADVERB (副詞)</span><b>${data.pos.adv.en}</b><p style="margin:5px 0 0 0; font-style:italic;">${data.pos.adv.ex}</p></div>` : ''}
            </div>

            <div class="nuance-box">
                <span class="nuance-title">🔍 Semantic Nuances (Phân biệt ngữ nghĩa)</span>
                <div>${data.nuance}</div>
            </div>

            <div class="extra-info-grid">
                <div class="info-card" style="border-left: 4px solid #2ecc71;">
                    <b style="color:#2ecc71;">Synonyms (近義詞):</b> ${data.synonyms}<br><br>
                    <b style="color:#e74c3c;">Antonyms (反義詞):</b> ${data.antonyms}
                </div>
                <div class="info-card" style="border-left: 4px solid #f1c40f;">
                    <b style="color:#d3a002;">Idioms / Sayings (成語俗語):</b>
                    <ul>${data.idioms.map(i => `<li>${i}</li>`).join('')}</ul>
                </div>
            </div>

            <div class="image-box">
                <img src="${data.image}" class="word-img" alt="${wordKey}">
            </div>

            <div class="video-container">
                <iframe src="${data.videoUrl}" allowfullscreen></iframe>
            </div>

            ${quizHtml}
        </div>
    `;

    // Gọi thư viện vẽ thứ tự nét chữ từ API HanziWriter bên ngoài vào vùng ẩn vừa hiển thị
    wordKey.split("").forEach(char => {
        const span = document.createElement("span");
        span.className = "hanzi-writer-container";
        document.getElementById("writer-area").appendChild(span);
        const writer = HanziWriter.create(span, char, {
            width: 80,
            height: 80,
            padding: 5,
            strokeColor: '#d12127',
            showOutline: true
        });
        span.onclick = () => writer.animateCharacter();
        writer.animateCharacter();
    });
}

// Chức năng phát âm Audio
function speak(text, lang = 'zh-CN') {
    window.speechSynthesis.cancel();
    const msg = new SpeechSynthesisUtterance(text);
    msg.lang = lang;
    window.speechSynthesis.speak(msg);
}

// Chấm điểm Quiz trắc nghiệm ngắn
function checkQuiz(btn, qIdx, oIdx, correctIdx, wordKey) {
    const parent = btn.parentElement;
    const options = parent.querySelectorAll(".quiz-option");
    
    options.forEach(opt => opt.disabled = true);
    
    if (oIdx === correctIdx) {
        btn.style.background = "#2ecc71";
        btn.style.color = "white";
        totalScore += 10;
    } else {
        btn.style.background = "#e74c3c";
        btn.style.color = "white";
        options[correctIdx].style.background = "#2ecc71";
        options[correctIdx].style.color = "white";
    }
    document.getElementById(`score-${wordKey}`).innerText = `Current Session Score: ${totalScore}`;
}

// Click chuột bên ngoài vùng search sẽ đóng dropdown menu
document.addEventListener("click", function(e) {
    if (e.target.id !== "search") {
        document.getElementById("suggest").style.display = "none";
    }
});
</script>

