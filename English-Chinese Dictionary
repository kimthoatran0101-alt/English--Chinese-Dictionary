    ipa: "[fa˥ ʈʂan˨˩˦]",
    englishIpa: "/dɪˈveləp/ & /ˈɡroʊθ/",
    searchKeywords: ["develop", "development", "growth", "grow", "fazhan"],
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600",
